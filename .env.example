# Supabase — single source of truth for tokens, agent state, sensors
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron / ingest auth
AGENT_CRON_SECRET=your-cron-bearer-secret
THERMOLEO_INGEST_SECRET=your-sensor-ingest-secret
THERMOLEO_ALLOWED_ORIGIN=https://your-deployment.vercel.app
THERMOLEO_SHELLY_TOKEN=your-shelly-webhook-token

# Sabiana Cloud — hydronic fancoils
SABIANA_EMAIL=you@example.com
SABIANA_PASSWORD=your-sabiana-password

# Netatmo — radiator valves
NETATMO_CLIENT_ID=your-netatmo-client-id
NETATMO_CLIENT_SECRET=your-netatmo-client-secret
NETATMO_REDIRECT_URI=https://your-deployment.vercel.app/api/netatmo/callback

# Legrand / Bticino Smarther — zone-valve thermostat
LEGRAND_CLIENT_ID=your-legrand-client-id
LEGRAND_CLIENT_SECRET=your-legrand-client-secret
LEGRAND_REDIRECT_URI=https://your-deployment.vercel.app/api/legrand/callback
LEGRAND_SUBSCRIPTION_KEY=your-legrand-subscription-key

# Homey — Sonoff sensor bridge
HOMEY_CLIENT_ID=your-homey-client-id
HOMEY_CLIENT_SECRET=your-homey-client-secret
HOMEY_LOCAL_IP=192.168.1.x
HOMEY_SESSION_TOKEN=your-homey-session-token

# MELCloud — Mitsubishi reversible splits
MELCLOUD_EMAIL=you@example.com
MELCLOUD_PASSWORD=your-melcloud-password

# iMessage alerting (best-effort, optional)
IMESSAGE_PROXY_URL=http://localhost:9100
IMESSAGE_RECIPIENT=you@example.com
